{
  "name": "@risk-tolerance/svelte-adapter-bun",
  "version": "1.6.0",
  "description": "Adapter for SvelteKit apps that generates a standalone Bun.js server. Maintained fork of svelte-adapter-bun.",
  "keywords": [
    "adapter",
    "deploy",
    "svelte",
    "sveltekit",
    "bun"
  ],
  "author": {
    "name": "Volodymyr Palamar",
    "url": "https://gornostay25.dev",
    "email": "me@gornostay25.dev"
  },
  "contributors": [
    {
      "name": "Isaac Druin",
      "url": "https://github.com/RiskTolerance"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RiskTolerance/sv-adapter-bun.git"
  },
  "bugs": {
    "url": "https://github.com/RiskTolerance/sv-adapter-bun/issues"
  },
  "homepage": "https://github.com/RiskTolerance/sv-adapter-bun#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "husky || echo ''",
    "build": "bun run scripts/build.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration --timeout 180000"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "index.d.ts",
  "files": [
    "dist",
    "index.d.ts",
    "ambient.d.ts"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "prettier": "3.6.2",
    "rolldown": "^1.1.1",
    "sirv": "file:packages/sirv"
  },
  "peerDependencies": {
    "typescript": "^5",
    "@sveltejs/kit": "^2.4.0",
    "rolldown": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "rolldown": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">=1.3.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
